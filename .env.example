# --- required ---
# Must be at least 16 characters. Used to seal session cookies and encrypt tokens.
CORE_SECRET="change-me-to-a-long-random-secret"

# Either DATABASE_URL, or all of DATABASE_USERNAME/PASSWORD/HOST/PORT/NAME.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zipfast"

# --- core (optional) ---
CORE_PORT=3000
CORE_HOSTNAME=0.0.0.0
# Emit https:// URLs and mark cookies Secure (set true behind TLS).
CORE_RETURN_HTTPS_URLS=false
CORE_TRUST_PROXY=false
# CORE_DEFAULT_DOMAIN=cdn.example.com
# CORE_TEMP_DIRECTORY=/tmp/zipline

# --- datasource ---
# local | s3
DATASOURCE_TYPE=local
DATASOURCE_LOCAL_DIRECTORY=./uploads
# For S3 (set DATASOURCE_TYPE=s3):
# DATASOURCE_S3_ACCESS_KEY_ID=...
# DATASOURCE_S3_SECRET_ACCESS_KEY=...
# DATASOURCE_S3_REGION=us-east-1
# DATASOURCE_S3_BUCKET=zipfast
# DATASOURCE_S3_ENDPOINT=            # custom endpoint host (e.g. MinIO); blank = AWS
# DATASOURCE_S3_FORCE_PATH_STYLE=false
# DATASOURCE_S3_SUBDIRECTORY=
#
# Backblaze B2: use DATASOURCE_TYPE=s3 and set DATASOURCE_S3_ENDPOINT to your
# bucket's S3 endpoint, e.g. s3.us-west-004.backblazeb2.com (keyID = access key,
# applicationKey = secret), with DATASOURCE_S3_REGION matching that endpoint.

# --- files / urls ---
FILES_ROUTE=/u
FILES_LENGTH=6
FILES_DEFAULT_FORMAT=random        # random | uuid | date | name | gfycat | random-words
FILES_MAX_FILE_SIZE=100mb
# FILES_EXTENSIONLESS_URLS=false
# FILES_REMOVE_GPS_METADATA=false
URLS_ROUTE=/go
URLS_LENGTH=6

# --- features ---
FEATURES_IMAGE_COMPRESSION=true
FEATURES_THUMBNAILS_ENABLED=true
FEATURES_USER_REGISTRATION=false
FEATURES_METRICS_ENABLED=true

# --- auth / mfa (optional) ---
# MFA_TOTP_ENABLED=true
# MFA_TOTP_ISSUER=Zipfast

# --- webhooks (optional) ---
# DISCORD_ON_UPLOAD_WEBHOOK_URL=
# HTTP_WEBHOOK_ON_UPLOAD=

# --- frontend / SPA serving (optional) ---
# By default the Go server serves the built SPA (from web/dist) and falls back to
# index.html for client routes. Build it with `make web`.
# ZIPFAST_WEB_DIR=./web/dist               # directory of the built SPA
# ZIPFAST_PUBLIC_API_URL=                  # injected into /config.js as window.__ZIPFAST_API__ (blank = same-origin)
#
# CDN option — host the SPA on a CDN and turn OFF in-binary client serving
# (the server becomes API-only). Set EITHER of these:
# ZIPFAST_CDN_URL=https://cdn.example.com  # presence disables local client serving
# ZIPFAST_DISABLE_WEB=false                # set true to disable client serving

# --- logging ---
# debug | info | warn | error
LOG_LEVEL=info

# --- output the OpenAPI/SPA build only when needed ---
# ZIPLINE_OUTPUT_OPENAPI=false
