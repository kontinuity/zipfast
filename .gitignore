# =====================================================================
# Zipfast .gitignore — ignore everything that isn't source.
# Kept on purpose: Go/web sources, Dockerfile, docker-compose.yml, Makefile,
# README.md, .dockerignore, rclone-exclude.txt, .env.example, configs,
# web/code.json, web/mimes.json, web/prisma/schema.prisma.
# =====================================================================

# ---- Go: binaries & build output ----
/bin/
/zipfast
/zipfastctl
*.exe
*.exe~
*.dll
*.so
*.dylib

# ---- Go: test / coverage / profiling ----
*.test
*.out
*.prof
coverage.*

# ---- Go: workspace & vendored deps ----
go.work
go.work.sum
/vendor/

# ---- Web client: dependencies, build output, generated code ----
node_modules/
/web/dist/
# generated by `prisma generate`
/web/src/prisma/
# vite / bundler caches
.vite/
**/.vite/
*.tsbuildinfo

# ---- Secrets & local config (keeps .env.example) ----
/.env
/.env.local
/.env.*.local

# ---- Local runtime data ----
/uploads/
/tmp/

# ---- Logs ----
*.log

# ---- OS junk ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editor / IDE ----
/.idea/
/.vscode/
*.swp
*.swo
*~
*.bak
